<% layout('/layouts/boilerplate') -%>

    <body>
        <div class="flex justify-center items-center py-12">
            <div class="flex flex-col gap-3 w-[40vw]">
                <h2 class="text-2xl font-semibold">Edit Listing</h2>

                <form method="POST" action="/listings/<%= listing._id %>?_method=PUT" class="flex flex-col gap-5 w-full"
                    id="form" novalidate>
                    <div>
                        <label for="title" class=" text-fg-success-strong">Title</label>
                        <input type="text" name="listing[title]" placeholder="Add a catchy title" id="title"
                            class="bg-success-soft border border-success-subtle text-fg-success-strong px-3 py-2 rounded-lg w-full"
                            value="<%= listing.title %>" required>
                        <p class="valid-feedback hidden text-green-600 text-sm mt-1">
                            Looks Good
                        </p>
                        <p class="invalid-feedback hidden text-red-600 text-sm mt-1">
                            Title is required!
                        </p>
                    </div>
                    <div>
                        <label for="description">Description</label>
                        <textarea name="listing[description]" id="" class="border px-3 py-2 rounded-lg w-full"
                            required><%= listing.description %></textarea>
                        <p class="valid-feedback hidden text-green-600 text-sm mt-1">
                            Looks Good
                        </p>
                        <p class="invalid-feedback hidden text-red-600 text-sm mt-1">
                            Description is required!
                        </p>
                    </div>
                    <div>
                        <label for="image">Image Link</label>
                        <input type="text" name="listing[image]" placeholder="Enter image URL/Link"
                            class="border px-3 py-2 rounded-lg w-full" value="<%= listing.image.url %>">
                    </div>
                    <div>
                        <label for="price">Price</label>
                        <input type="number" name="listing[price]" placeholder="1200" value="<%= listing.price %>"
                            class="border px-3 py-2 rounded-lg w-full" required>
                        <p class="valid-feedback hidden text-green-600 text-sm mt-1">
                            Looks Good
                        </p>
                        <p class="invalid-feedback hidden text-red-600 text-sm mt-1">
                            Price is required!
                        </p>
                    </div>
                    <div>
                        <label for="location">Location</label>
                        <input type="text" name="listing[location]" placeholder="Jaipur, Rajasthan" value="<%= listing.location %>" class="border px-3 py-2 rounded-lg w-full" required>
                        <p class="valid-feedback hidden text-green-600 text-sm mt-1">
                            Looks Good
                        </p>
                        <p class="invalid-feedback hidden text-red-600 text-sm mt-1">
                            Location is required!
                        </p>
                    </div>
                    <div>
                        <label for="country">Country</label>
                        <input type="text" name="listing[country]" placeholder="India" value="<%= listing.country %>"
                            class="border px-3 py-2 rounded-lg w-full" required>
                        <p class="valid-feedback hidden text-green-600 text-sm mt-1">
                            Looks Good
                        </p>
                        <p class="invalid-feedback hidden text-red-600 text-sm mt-1">
                            Country is required!
                        </p>
                    </div>
                    <button class="bg-[#FF5A5F] text-white px-3 py-2 rounded-lg w-full">Edit Listing</button>
                </form>
            </div>
        </div>
    </body>